generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String?  @unique
  phone           String   @unique
  passwordHash    String
  nickname        String
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  emailVerified   Boolean  @default(false)
  phoneVerified   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?

  conversations   Conversation[]
  healthRecords   HealthRecord[]
  subscriptions   Subscription[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revoked     Boolean  @default(false)

  @@index([userId])
  @@map("refresh_tokens")
}

model Conversation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  type        ConversationType
  model       String   @default("local-llm")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("conversations")
}

enum ConversationType {
  CHAT
  SEARCH
  REPORT
  DRUG
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String
  sources         Json?
  tokensUsed      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model HealthRecord {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            RecordType
  fileUrl         String
  fileName        String?
  fileSize        Int?
  parsedData      Json?
  analysisResult  Json?
  createdAt       DateTime @default(now())

  documentChunks  DocumentChunk[]

  @@index([userId])
  @@index([type])
  @@map("health_records")
}

enum RecordType {
  REPORT
  PRESCRIPTION
  EXAM
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        PlanType
  status      SubscriptionStatus
  startDate   DateTime
  endDate     DateTime?
  autoRenew   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("CNY")
  status          PaymentStatus
  paymentMethod   String?
  transactionId   String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model VerificationCode {
  id          String   @id @default(uuid())
  target      String
  code        String
  type        CodeType
  purpose     CodePurpose
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([target])
  @@index([expiresAt])
  @@map("verification_codes")
}

enum CodeType {
  PHONE
  EMAIL
}

enum CodePurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

model KnowledgeDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  source      String
  category    String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks      DocumentChunk[]

  @@index([category])
  @@map("knowledge_documents")
}

model DocumentChunk {
  id             String   @id @default(uuid())
  documentId     String
  document       KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  healthRecordId String?
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  content        String
  chunkIndex     Int
  embedding      Unsupported("Vector(1024)")?
  tokenCount     Int      @default(0)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([documentId])
  @@index([healthRecordId])
  @@map("document_chunks")
}

model FederatedSearchRecord {
  id            String   @id @default(uuid())
  userId        String
  query         String
  hospitalNodes Json     @default("[]")
  results       Json     @default("[]")
  aggregated    Boolean  @default(false)
  privacyBudget Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("federated_search_records")
}
