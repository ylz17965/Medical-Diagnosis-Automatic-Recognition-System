{
  "metadata": {
    "name": "边界情况测试集",
    "version": "1.0.0",
    "description": "测试系统对边界情况和异常输入的处理能力",
    "total_cases": 30,
    "categories": ["模糊输入", "多意图", "方言口语", "错误信息", "敏感内容", "紧急情况"]
  },
  "test_cases": [
    {
      "id": "E001",
      "category": "模糊输入",
      "input": "我不舒服",
      "expected_behavior": {
        "should_request_clarification": true,
        "expected_intent": "symptom_report"
      },
      "difficulty": 1
    },
    {
      "id": "E002",
      "category": "模糊输入",
      "input": "有点难受",
      "expected_behavior": {
        "should_request_clarification": true,
        "expected_intent": "symptom_report"
      },
      "difficulty": 1
    },
    {
      "id": "E003",
      "category": "多意图",
      "input": "我头痛而且想问问感冒吃什么药",
      "expected_behavior": {
        "should_handle_multiple_intents": true,
        "expected_intents": ["symptom_report", "drug_inquiry"],
        "expected_entities": ["头痛", "感冒"]
      },
      "difficulty": 3
    },
    {
      "id": "E004",
      "category": "多意图",
      "input": "高血压吃什么药，还需要做什么检查",
      "expected_behavior": {
        "should_handle_multiple_intents": true,
        "expected_intents": ["drug_inquiry", "examination_inquiry"],
        "expected_entities": ["高血压"]
      },
      "difficulty": 3
    },
    {
      "id": "E005",
      "category": "方言口语",
      "input": "脑壳疼",
      "expected_behavior": {
        "expected_intent": "symptom_report",
        "expected_entities": ["头痛"],
        "should_understand_colloquial": true
      },
      "difficulty": 2
    },
    {
      "id": "E006",
      "category": "方言口语",
      "input": "肚皮痛",
      "expected_behavior": {
        "expected_intent": "symptom_report",
        "expected_entities": ["腹痛"],
        "should_understand_colloquial": true
      },
      "difficulty": 2
    },
    {
      "id": "E007",
      "category": "方言口语",
      "input": "心里慌",
      "expected_behavior": {
        "expected_intent": "symptom_report",
        "expected_entities": ["心悸"],
        "should_understand_colloquial": true
      },
      "difficulty": 2
    },
    {
      "id": "E008",
      "category": "方言口语",
      "input": "不想吃饭",
      "expected_behavior": {
        "expected_intent": "symptom_report",
