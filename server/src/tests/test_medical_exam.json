      "difficulty": 1,
      "type": "single_choice",
      "question": "药物的副反应是",
      "options": {
        "A": "难以避免的",
        "B": "较严重的",
        "C": "与治疗目的有关的",
        "D": "剂量过大引起的",
        "E": "可以避免的"
      },
      "correct_answer": "A",
      "explanation": "副反应是药物在治疗剂量下出现的与治疗目的无关的作用，是药物固有的作用，难以避免，但一般较轻微。",
      "expected_retrieval": "vector",
      "key_entities": ["副反应", "药物作用"]
