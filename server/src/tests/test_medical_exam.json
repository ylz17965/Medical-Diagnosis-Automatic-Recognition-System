    {
      "id": "ME001",
      "category": "药理学",
      "difficulty": 1,
      "type": "single_choice",
      "question": "可引起首关消除的主要给药途径是",
      "options": {
        "A": "吸入给药",
        "B": "舌下给药",
        "C": "口服给药",
        "D": "直肠给药",
        "E": "皮下注射"
      },
      "correct_answer": "C",
      "explanation": "首关消除是指药物在通过肠黏膜和肝脏时，被代谢灭活的现象。口服给药后，药物经肠道吸收进入门静脉，再经肝脏进入体循环，因此口服给药最易发生首关消除。",
      "expected_retrieval": "vector",
      "key_entities": ["首关消除", "给药途径", "口服给药"]
    },
    {
      "id": "ME002",
