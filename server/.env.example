# ==========================================
# 智疗助手 - 环境配置模板
# ==========================================
# 使用方法：
# 1. 复制本文件为 .env：copy .env.example .env
# 2. 修改下面的配置项
# 3. 运行：npm run dev
# ==========================================

# === 基础配置 ===
NODE_ENV=development
PORT=3001

# === 数据库配置 ===
# PostgreSQL 连接字符串，格式：postgresql://用户名:密码@主机:端口/数据库名
# 本地开发默认使用 postgres 用户，请替换密码部分
DATABASE_URL="postgresql://postgres:你的数据库密码@localhost:5432/zhiliao?schema=public"

# === Redis 配置（可选，用于会话缓存）===
REDIS_URL="redis://localhost:6379"

# === JWT 配置 ===
# 生成随机密钥：openssl rand -base64 48
JWT_SECRET="替换为至少32位随机字符串"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# === Cookie 配置 ===
COOKIE_SECRET="替换为至少32位随机字符串"

# === CORS 跨域配置 ===
# 前端开发服务器地址
CORS_ORIGIN="http://localhost:5173"

# === 阿里云百炼 API 配置 ===
# 1. 注册并获取 API Key：https://bailian.console.aliyun.com/
# 2. 将下方替换为你的真实 Key
QWEN_API_KEY="sk-替换为你的阿里云百炼APIKey"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# === 模型配置 ===
# qwen-max：复杂问题（深度分析、报告解读）
# qwen3.5-flash：简单问答（日常对话）
QWEN_MODEL_COMPLEX="qwen-max"
QWEN_MODEL_SIMPLE="qwen3.5-flash"

# 文本嵌入模型（用于向量搜索）
QWEN_MODEL_EMBEDDING="text-embedding-v3"

# 重排序模型（用于 RAG 优化）
QWEN_MODEL_RERANK="qwen3-rerank"

# 视觉模型（用于图片识别）
QWEN_MODEL_VISION="qwen3-vl-plus"
QWEN_MODEL_OCR="qwen-vl-ocr"

# === 向量搜索配置 ===
# 向量维度，与嵌入模型保持一致
EMBEDDING_DIMENSION=1024

# === RAG 检索配置 ===
# 最终返回的文档数量
RAG_TOP_K=5

# 重排序阶段保留的文档数量
RAG_RERANK_TOP_K=10

# 文本分块大小（字符数）
RAG_CHUNK_SIZE=512

# 文本分块重叠大小（字符数）
RAG_CHUNK_OVERLAP=128

# 向量相似度阈值（0-1，越高越严格）
RAG_SIMILARITY_THRESHOLD=0.7
