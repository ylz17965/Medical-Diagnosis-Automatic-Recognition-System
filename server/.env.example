NODE_ENV=development
PORT=3001

# 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhiliao?schema=public"

# Redis (可选)
REDIS_URL=""

# JWT 配置
JWT_SECRET="your-64-character-random-string-here-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Cookie 配置
COOKIE_SECRET="your-64-character-random-string-here-change-in-production"

# CORS
CORS_ORIGIN="http://localhost:5173"

# LLM 配置
LLM_PROVIDER="qwen"
QWEN_API_KEY=""

# 向量嵌入配置
EMBEDDING_PROVIDER="qwen"
EMBEDDING_DIMENSION=768

# RAG 配置
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
