NODE_ENV=development
PORT=3001

# 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zhiliao?schema=public"

# Redis (可选)
REDIS_URL=""

# JWT 配置
JWT_SECRET="your-64-character-random-string-here-change-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Cookie 配置
COOKIE_SECRET="your-64-character-random-string-here-change-in-production"

# CORS
CORS_ORIGIN="http://localhost:5173"

# 阿里云百炼 API 配置
QWEN_API_KEY="your-qwen-api-key-here"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 模型配置 (使用阿里云百炼平台)
QWEN_MODEL_COMPLEX="qwen-max"
QWEN_MODEL_SIMPLE="qwen3.5-flash"
QWEN_MODEL_EMBEDDING="text-embedding-v3"
QWEN_MODEL_RERANK="qwen3-rerank"
QWEN_MODEL_VISION="qwen3-vl-plus"
QWEN_MODEL_OCR="qwen-vl-ocr"

# 向量嵌入配置
EMBEDDING_DIMENSION=1024

# RAG 配置
RAG_TOP_K=5
RAG_RERANK_TOP_K=20
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128
RAG_SIMILARITY_THRESHOLD=0.7
