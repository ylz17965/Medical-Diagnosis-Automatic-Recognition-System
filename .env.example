# ============================================
# 生产环境变量示例
# ============================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入真实的密钥和 API key
# ============================================

# 数据库密码（生产环境请使用强密码）
POSTGRES_PASSWORD=zhiliao123

# JWT 密钥（请使用 64 位随机字符串）
# 生成方法：openssl rand -base64 48
JWT_SECRET=your-64-character-random-string-here-change-in-production

# Cookie 密钥（请使用 64 位随机字符串）
COOKIE_SECRET=your-64-character-random-string-here-change-in-production

# 阿里云百炼 API 密钥（必须填入真实密钥）
QWEN_API_KEY=your-qwen-api-key-here
